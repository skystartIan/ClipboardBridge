<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 讀取 /sdcard/cb_b64.txt（大圖繞過 Binder 限制用）-->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <!-- 進出 RDP 時切換輸入法子類型（寫 selected_input_method_subtype）。
         一般 App 拿不到，要用 adb 授予一次：
         adb shell pm grant com.clipboardbridge android.permission.WRITE_SECURE_SETTINGS
         簽章固定，之後 adb install -r 不會掉。 -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:label="ClipboardBridge"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ClipboardActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:launchMode="singleInstance" />

        <receiver
            android:name=".ClipboardReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="com.clipboardbridge.SET_IMAGE" />
            </intent-filter>
        </receiver>

        <service
            android:name=".ClipboardService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- 框選截圖服務：硬體 F1 鍵 + PC 控制指令 6 兩個入口 -->
        <service
            android:name=".ShotService"
            android:exported="true"
            android:label="ClipboardBridge 框選截圖"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/shot_service" />
        </service>

        <!-- 通知監聽服務 -->
        <service
            android:name=".NotificationService"
            android:exported="true"
            android:label="ClipboardBridge 通知"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- 分享檔案給 LINE 用（LineShare）：由 App 自己授權 URI，
             shell 身分的 adb 做不到這件事 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.clipboardbridge.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="com.clipboardbridge.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true" />

    </application>

</manifest>
